rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Default Deny - Security Foundation
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && (
        (request.auth.token.email != null && request.auth.token.email.lower() == "mahamudurrahman778@gmail.com") ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin")
      ); 
    }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Validation Helpers ---
    
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid == request.auth.uid &&
             data.uid is string &&
             data.role is string;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['senderId', 'text', 'timestamp', 'seen', 'type']) &&
             data.senderId == request.auth.uid &&
             data.text is string && data.text.size() <= 5000 &&
             data.type in ['text', 'image', 'file'];
    }

    // --- Rules ---

    // User Profiles - Strict Identity Guard
    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(incoming()) && isValidId(userId);
      allow update: if (
        isOwner(userId) && 
        incoming().role == existing().role && 
        incoming().uid == existing().uid
      ) || isAdmin();
    }

    // Public Listings - Open Read, Restricted Write
    match /tools/{toolId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /scripts/{scriptId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /apps/{appId} {
      allow read: if true;
      allow update: if (
        incoming().diff(existing()).affectedKeys().hasOnly(['downloadsCount']) ||
        isAdmin()
      );
      allow create, delete: if isAdmin();
    }

    // Downloads tracking
    match /downloads/{downloadId} {
      allow read: if isAdmin();
      allow create: if true; // Tracking downloads can be open
    }

    // Settings / Owner Bio
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Admin Whitelist - For backend lookups
    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if false; 
    }

    // Support Chat - Relational Access Control
    match /chats/{chatId} {
      allow read: if isSignedIn() && (request.auth.uid in existing().participants || isAdmin());
      allow create: if isSignedIn() && isValidId(chatId); 
      allow update: if isSignedIn() && (
        (request.auth.uid in existing().participants && incoming().diff(existing()).affectedKeys().hasAny(['updatedAt', 'lastMessage'])) ||
        isAdmin()
      );

      match /messages/{messageId} {
        allow read: if isSignedIn() && (get(/databases/$(database)/documents/chats/$(chatId)).data.participants.hasAny([request.auth.uid]) || isAdmin());
        allow create: if isSignedIn() && isValidMessage(incoming()) && (get(/databases/$(database)/documents/chats/$(chatId)).data.participants.hasAny([request.auth.uid]) || isAdmin());
        allow update: if isSignedIn() && (
          (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants && incoming().diff(existing()).affectedKeys().hasOnly(['seen'])) ||
          isAdmin()
        );
      }
    }
  }
}
